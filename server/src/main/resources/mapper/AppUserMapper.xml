<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pyisland.server.repository.AppUserMapper">

    <resultMap id="AppUserResultMap" type="AppUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="avatar" column="avatar"/>
        <result property="sessionToken" column="session_token"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectByUsername" resultMap="AppUserResultMap">
        SELECT id, username, password, avatar, session_token, created_at
        FROM app_user
        WHERE username = #{username}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO app_user (username, password, avatar, created_at)
        VALUES (#{username}, #{password}, #{avatar}, #{createdAt})
    </insert>

    <update id="updateSessionToken">
        UPDATE app_user
        SET session_token = #{sessionToken}
        WHERE username = #{username}
    </update>

</mapper>
